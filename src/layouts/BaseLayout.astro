---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Leo Merlo — Senior Frontend Engineer',
  description = 'I build frontend systems that teams actually use. Design systems, accessibility architecture, and distributed team alignment.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Leo Merlo" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link" data-i18n="skip-link">Skip to main content</a>

    <div class="relative">
      <slot />
    </div>

    <script>
      import { ui } from '../i18n/ui';
      import type { Lang, TranslationKey } from '../i18n/ui';

      // ── Lang helpers ──────────────────────────────────────────
      function getLang(): Lang {
        return (localStorage.getItem('lang') as Lang) || 'en';
      }

      function applyLang(lang: Lang) {
        const t = ui[lang];

        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const key = el.dataset.i18n as TranslationKey;
          if (key in t) el.textContent = t[key];
        });

        document.querySelectorAll<HTMLElement>('[data-i18n-aria]').forEach((el) => {
          const key = el.dataset.i18nAria as TranslationKey;
          if (key in t) el.setAttribute('aria-label', t[key]);
        });

        document.documentElement.setAttribute('lang', lang);

        document.querySelectorAll('.lang-toggle').forEach((toggle) => {
          const isEs = lang === 'es';
          toggle.querySelector('.lang-en')?.classList.toggle('lang-active', !isEs);
          toggle.querySelector('.lang-es')?.classList.toggle('lang-active', isEs);
          toggle.setAttribute('aria-label', t['lang-toggle.label']);
        });

        // Update theme toggle aria-label to match current lang
        const themeBtn = document.getElementById('theme-toggle');
        if (themeBtn) {
          const isLight = document.documentElement.classList.contains('light');
          const key: TranslationKey = isLight ? 'theme-toggle.to-dark' : 'theme-toggle.to-light';
          themeBtn.setAttribute('aria-label', t[key]);
        }
      }

      // ── Boot ─────────────────────────────────────────────────
      const currentLang = getLang();
      applyLang(currentLang);

      // ── Lang toggle ──────────────────────────────────────────
      document.querySelectorAll('.lang-toggle').forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const next: Lang = getLang() === 'en' ? 'es' : 'en';
          localStorage.setItem('lang', next);
          applyLang(next);
        });
      });

      // ── Active nav link via IntersectionObserver ─────────────
      const sections = document.querySelectorAll('.section[id]');
      const navLinks = document.querySelectorAll('.nav-link');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((l) => l.classList.remove('active'));
            const active = document.querySelector(`.nav-link[href="#${entry.target.id}"]`);
            active?.classList.add('active');
          }
        });
      }, { rootMargin: '-30% 0px -60% 0px' });

      sections.forEach((s) => observer.observe(s));
    </script>
  </body>
</html>

