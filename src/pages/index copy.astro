---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>

  <!-- ══════════════════ PROMO STRIP ══════════════════ -->
  <div class="promo-strip" role="banner" aria-label="Status">
    <span>Open to remote work</span>
    <strong>· Buenos Aires, Argentina ·</strong>
    <span>Senior Frontend Engineer</span>
    <strong>· Available now ·</strong>
    <span>Open to remote work</span>
  </div>

  <!-- ══════════════════ NAV ══════════════════ -->
  <header class="site-nav" role="banner">
    <div class="nav-inner">
      <a href="/" class="nav-brand" aria-label="Leandro Merlo — home">
        <span class="nav-brand-mark" aria-hidden="true">⚡</span>
        LEANDRO MERLO.
      </a>

      <nav class="nav-links" aria-label="Page sections">
        <a href="#about" class="nav-link">About</a>
        <a href="#skills" class="nav-link">Skills</a>
        <a href="#work" class="nav-link">Work</a>
      </nav>

      <div class="nav-right">
        <a href="https://linkedin.com/in/merloleandro" target="_blank" rel="noopener noreferrer" class="nav-resume">
          LinkedIn
        </a>
        <a href="mailto:merloleandro@gmail.com" class="nav-contact">
          · Contact Me
        </a>

        <button
          id="theme-toggle"
          class="theme-toggle"
          type="button"
          aria-label="Switch to dark mode"
        >
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main id="main-content" tabindex="-1">

    <!-- ══════════════════ HERO ══════════════════ -->
    <section class="hero" aria-label="Introduction">
      <div class="container">
        <h1 class="hero-headline">
          The Engineer's Way to<br>a Stronger Frontend.
        </h1>

        <div class="hero-grid">

          <!-- Left: floating spec badges (like Enerloc features) -->
          <div class="hero-specs">
            <div class="hero-spec">
              <div class="spec-icon" aria-hidden="true">⚡</div>
              <div class="spec-label">High adoption<br>&amp; efficiency</div>
              <div class="spec-desc">Design systems built to be chosen, not mandated — 80%+ adoption across 6 teams</div>
            </div>
            <div class="hero-spec">
              <div class="spec-icon spec-icon--yellow" aria-hidden="true">🛡</div>
              <div class="spec-label">10+ years<br>of experience</div>
              <div class="spec-desc">Frontend architecture designed to meet real product demands, not just deadlines</div>
            </div>
          </div>

          <!-- Center: photo split panel (like Enerloc product duo) -->
          <div class="hero-center" role="img" aria-label="Portrait of Leandro Merlo">
            <div class="hero-photo-panel">
              <img
                src="/leo-main.jpg"
                alt="Leandro Merlo"
                class="hero-photo"
                width="480"
                height="600"
                loading="eager"
                decoding="async"
              />
            </div>
            <div class="hero-counter-panel" aria-label="80 percent team adoption">
              <div class="counter-n">80%</div>
              <div class="counter-lbl">Team adoption across distributed orgs</div>
            </div>
          </div>

          <!-- Right: stat column (like Enerloc "16x" card) -->
          <div class="hero-stat" role="region" aria-label="Key result">
            <span class="hero-stat-tag">Result</span>
            <div class="hero-stat-n" aria-label="minus 30 percent">−30%</div>
            <p class="hero-stat-desc">
              Review cycle reduction — accessible patterns built into the system from day one.
            </p>
            <a href="#work" class="hero-stat-link">
              See my work ↗
            </a>
            <div class="hero-stat-cta2">
              <a href="#about" class="play-btn" aria-label="Learn how I work">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
              </a>
              <span>How I work</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════ SKILLS ("Advanced brush & paste" equiv.) ══════════════════ -->
    <section class="skills-section section" id="skills" aria-labelledby="skills-heading">
      <div class="container">
        <div class="skills-header">
          <h2 id="skills-heading" class="skills-title">
            Design Systems · A11y<br>&amp; Leadership.
          </h2>
          <div class="skills-tabs" role="list" aria-label="Skill areas">
            <span class="skill-tab skill-tab--active" role="listitem">Design Systems</span>
            <span class="skill-tab" role="listitem">Accessibility</span>
            <span class="skill-tab" role="listitem">Leadership</span>
            <span class="skill-tab" role="listitem">Architecture</span>
          </div>
        </div>

        <div class="skills-cards">

          <!-- Yellow card: Design Systems (like "Conducting power the right way") -->
          <article class="skill-card skill-card--yellow" aria-label="Design Systems">
            <div class="skill-cat">
              <span>Design System</span>
            </div>
            <h3 class="skill-card-title">Conducting adoption the right way.</h3>
            <p class="skill-card-desc">
              Framework-agnostic, token-first architecture. Storybook as the shared contract between design and engineering.
            </p>
            <div class="skill-card-big" aria-hidden="true">80%</div>
            <a href="#work" class="skill-card-cta">
              SEE THE SYSTEM ↗
            </a>
          </article>

          <!-- Pink card: A11y (like "Electric brush for everyone") -->
          <article class="skill-card skill-card--pink" aria-label="Accessibility">
            <div class="skill-cat">Accessibility</div>
            <h3 class="skill-card-title">Built right,<br>for everyone.</h3>
            <p class="skill-card-desc">
              WCAG compliance as an architectural constraint — axe-core in CI, semantic patterns in every component.
            </p>
            <div class="skill-card-big" aria-hidden="true">−30%</div>
            <a href="#work" class="skill-card-cta">
              VIEW APPROACH ↗
            </a>
          </article>

          <!-- Blue card: Leadership (like "Always in contact with quality") -->
          <article class="skill-card skill-card--blue" aria-label="Frontend Leadership">
            <div class="skill-cat">Leadership</div>
            <h3 class="skill-card-title">Always aligned<br>with teams.</h3>
            <p class="skill-card-desc">
              RFC-driven Frontend Guild across 6 distributed teams — shared standards built on trust, not org chart authority.
            </p>
            <div class="skill-card-big" aria-hidden="true">6</div>
            <a href="#work" class="skill-card-cta">
              READ MORE ↗
            </a>
          </article>

        </div>
      </div>
    </section>

    <!-- ══════════════════ ABOUT ("Smile like you mean it" equiv.) ══════════════════ -->
    <section class="about-section section" id="about" aria-labelledby="about-heading">
      <div class="container">
        <div class="about-grid">

          <!-- Left: headline + quote + CTA -->
          <div class="about-left">
            <div>
              <h2 id="about-heading" class="about-headline">
                Ship it like<br>you mean it.
              </h2>
              <p class="about-quote">
                I'm a fullstack developer with a strong frontend focus — 10+ years building the kind of systems that hold up under real product pressure. My work lives at the intersection of engineering quality, design consistency, and team scale.
              </p>
              <div class="about-person">
                <img src="/leo-main.jpg" alt="" class="about-avatar" width="40" height="40" aria-hidden="true" />
                <div>
                  <div class="about-name">Leandro Merlo</div>
                  <div class="about-role">Senior Frontend Engineer</div>
                </div>
              </div>
            </div>
            <div class="about-bottom">
              <a href="mailto:merloleandro@gmail.com" class="about-cta">
                Get in touch ↗
              </a>
              <div class="about-years">
                <div class="about-years-n">10+</div>
                <div class="about-years-lbl">Years of<br>experience</div>
              </div>
            </div>
          </div>

          <!-- Center: photo -->
          <div class="about-center">
            <img
              src="/leo-main.jpg"
              alt="Leandro Merlo"
              class="about-photo"
              width="480"
              height="560"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- Right: stat cards -->
          <div class="about-right" aria-label="Career metrics">
            <div class="about-stat-card">
              <div class="about-stat-n">6</div>
              <div class="about-stat-lbl">Teams aligned through the Frontend Guild</div>
            </div>
            <div class="about-stat-card">
              <div class="about-stat-n">−30%</div>
              <div class="about-stat-lbl">Reduction in review cycles via a11y architecture</div>
            </div>
            <div class="about-tags" aria-label="Stack">
              {['React', 'TypeScript', 'Node.js', 'Design Tokens', 'Storybook', 'WCAG', 'SCSS', 'axe-core', 'CI/CD'].map((t) => (
                <span class="about-tag">{t}</span>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════ WORK BENTO ══════════════════ -->
    <section class="work-section section" id="work" aria-labelledby="work-heading">
      <div class="container">
        <div class="work-header">
          <div>
            <p class="work-eyebrow">Selected work</p>
            <h2 id="work-heading" class="work-title">What I've built.</h2>
          </div>
        </div>

        <div class="work-bento">

          <!-- Wide card: Design System -->
          <article class="work-card work-card--wide" aria-label="Design System at Scale">
            <div class="work-card-inner">
              <span class="work-card-metric">80%+ adoption</span>
              <h3 class="work-card-title">Design System at Scale</h3>
              <p class="work-card-desc">
                Built with one constraint: it had to win on merit. No mandate, no exec decree. Token-first architecture, framework-agnostic components, Storybook as the shared contract. The measure of success wasn't "did we ship" — it was "did teams choose to use it twice."
              </p>
              <ul class="work-card-tags" role="list" aria-label="Technologies">
                {['Design Tokens', 'Storybook', 'Web Components', 'TypeScript', 'SCSS'].map((t) => (
                  <li class="tag">{t}</li>
                ))}
              </ul>
            </div>
          </article>

          <!-- A11y card -->
          <article class="work-card" aria-label="Accessibility as Architecture">
            <div class="work-card-inner">
              <span class="work-card-metric">−30% review cycles</span>
              <h3 class="work-card-title">Accessibility as Architecture</h3>
              <p class="work-card-desc">
                Shifted a11y left — from QA checkbox to architectural constraint. Accessible patterns in the system, axe-core in CI, WCAG as part of the definition of done.
              </p>
              <ul class="work-card-tags" role="list" aria-label="Technologies">
                {['WCAG 2.1', 'axe-core', 'ARIA', 'CI/CD'].map((t) => (
                  <li class="tag">{t}</li>
                ))}
              </ul>
            </div>
          </article>

          <!-- Frontend Guild card -->
          <article class="work-card" aria-label="Frontend Guild">
            <div class="work-card-inner">
              <span class="work-card-metric">6 teams aligned</span>
              <h3 class="work-card-title">Frontend Guild</h3>
              <p class="work-card-desc">
                Built shared standards across 6 distributed teams through RFCs and trust, not process. 18 months — shared tooling, testing patterns, and performance budgets that teams actually chose.
              </p>
              <ul class="work-card-tags" role="list" aria-label="Technologies">
                {['RFC process', 'Developer experience', 'Cross-team alignment'].map((t) => (
                  <li class="tag">{t}</li>
                ))}
              </ul>
            </div>
          </article>

        </div>
      </div>
    </section>

  </main>

  <!-- ══════════════════ CONTACT ══════════════════ -->
  <section class="contact-section" id="contact" aria-labelledby="contact-heading">
    <div class="container">
      <div class="contact-inner">
        <div>
          <h2 id="contact-heading" class="contact-headline">
            Let's build<br>something.
          </h2>
          <p class="contact-sub">
            If you're building something where frontend architecture matters, I'd like to hear about it.
          </p>
        </div>

        <nav aria-label="Contact links">
          <ul class="contact-links" role="list">
            {[
              { href: 'mailto:merloleandro@gmail.com',        label: 'merloleandro@gmail.com',      external: false },
              { href: 'https://linkedin.com/in/merloleandro', label: 'linkedin.com/in/merloleandro', external: true  },
              { href: 'https://github.com/leomerlo',          label: 'github.com/leomerlo',          external: true  },
            ].map(({ href, label, external }) => (
              <li>
                <a
                  href={href}
                  class="contact-link"
                  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  <span class="contact-link-arrow" aria-hidden="true">↗</span>
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>
  </section>

  <!-- ══════════════════ FOOTER ══════════════════ -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-brand">
        <span aria-hidden="true">⚡</span>
        LEANDRO MERLO.
      </div>
      <nav class="footer-nav" aria-label="Footer links">
        <a href="mailto:merloleandro@gmail.com">Contact</a>
        <a href="https://github.com/leomerlo" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://linkedin.com/in/merloleandro" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </nav>
      <span class="footer-copy">© 2026 Leandro Merlo. Built with Astro + Tailwind.</span>
    </div>
  </footer>

</BaseLayout>
