---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'Design System at Scale',
    description: 'Framework-agnostic, token-based design system built to be adopted — not just installed.',
    metric: '80%+ team adoption',
    summary: 'I built this with one constraint: it had to win on merit. No mandate, no exec decree. That meant treating the system as a product — clear onboarding, honest documentation, a migration path from wherever teams already were.',
    details: 'Architecture was token-first: semantic color, spacing, and typography tokens that worked whether a team was on React, Angular, or a legacy stack. Storybook served as the contract between design and engineering. The measure of success wasn\'t "did we ship components" — it was "did teams choose to use them twice."',
    tags: ['Design Tokens', 'Storybook', 'Web Components', 'TypeScript', 'SCSS'],
  },
  {
    title: 'Accessibility as Architecture',
    description: 'Moved a11y from a QA checkbox to an architectural constraint. Cut review cycles by 30%.',
    metric: '−30% review cycles',
    summary: 'The problem wasn\'t awareness — engineers knew a11y mattered. The problem was friction: fixes were expensive because they happened at the end. The fix was to shift the cost left.',
    details: 'Accessible patterns went directly into the design system: focus management, ARIA semantics, keyboard navigation baked into every component. Automated axe-core checks ran in CI. WCAG compliance stopped being a separate pass and became part of the definition of done.',
    tags: ['WCAG 2.1', 'axe-core', 'ARIA', 'CI/CD'],
  },
  {
    title: 'Frontend Guild',
    description: 'Built shared standards across 6 distributed teams — without org chart authority.',
    metric: '6 teams aligned',
    summary: 'When you lead without formal authority, you ship standards by making them worth adopting. I started a Frontend Guild: a lightweight structure for cross-team alignment that ran on trust and usefulness, not process.',
    details: 'The format was RFC-driven: any engineer could propose a standard, the guild would discuss, teams could opt in. Over 18 months, 6 teams converged on shared tooling, testing patterns, and performance budgets — not because they had to, but because the defaults were genuinely good.',
    tags: ['RFC process', 'Developer experience', 'Cross-team alignment'],
  },
];
---

<BaseLayout>
  <div class="layout">

    <!-- ════════════════════════════════════
         LEFT — sticky sidebar
         ════════════════════════════════════ -->
    <header class="sidebar" aria-label="Site header">
      <div class="sidebar-inner">

        <div class="sidebar-top">
          <a href="/" aria-label="Leandro Merlo — home">
            <h1 class="site-name">Leandro<br/>Merlo</h1>
          </a>
          <p class="site-title">Fullstack Developer, Frontend Focused</p>
          <p class="site-tagline">
            I build frontend systems that teams actually use.
          </p>

          <nav class="sidebar-nav" aria-label="Page sections">
            <ul>
              {[
                ['#about',   'About'],
                ['#work',    'Work'],
                ['#contact', 'Contact'],
              ].map(([href, label]) => (
                <li>
                  <a href={href} class="nav-link">
                    <span class="nav-indicator" aria-hidden="true"></span>
                    <span>{label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>

        <div class="sidebar-bottom">
          <nav aria-label="Social links">
            <ul class="social-links" role="list">
              <li>
                <a href="https://github.com/leomerlo" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                </a>
              </li>
              <li>
                <a href="https://linkedin.com/in/merloleandro" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              </li>
              <li>
                <a href="mailto:merloleandro@gmail.com" class="social-link" aria-label="Send email">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                </a>
              </li>
            </ul>
          </nav>

          <p class="sidebar-footer">
            Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" style="color: var(--text-bright);">Astro</a>
            + <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" style="color: var(--text-bright);">Tailwind</a>.
            Source on <a href="https://github.com/leomerlo" target="_blank" rel="noopener noreferrer" style="color: var(--text-bright);">GitHub</a>.
          </p>
        </div>

      </div>
    </header>

    <!-- ════════════════════════════════════
         RIGHT — scrollable content
         ════════════════════════════════════ -->
    <main id="main-content" class="content" tabindex="-1">

      <!-- ── About ── -->
      <section id="about" class="section" aria-labelledby="about-heading">
        <div class="section-header-mobile">
          <h2 id="about-heading">About</h2>
        </div>

        <div class="about-content">
          <!--
            PHOTO: Replace with:
            <img src="/photo.jpg" alt="Portrait of Leandro Merlo" class="about-photo" width="140" height="140" loading="lazy">
          -->
          <div class="photo-placeholder" role="img" aria-label="Profile photo placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.58-7 8-7s8 3 8 7"/>
            </svg>
            <span>Your photo</span>
          </div>

          <p>
            I'm a fullstack developer with a strong frontend focus — 10+ years building the kind of systems that hold up under real product pressure. My work lives at the intersection of engineering quality, design consistency, and team scale.
          </p>
          <p>
            I've built design systems from scratch that reached 80%+ adoption across distributed teams — not by mandate, but by making them genuinely better to use than the alternative. Token-first architecture, framework-agnostic components, and Storybook as the shared contract between design and engineering.
          </p>
          <p>
            I treat accessibility as architecture, not audit. When a11y constraints live in the system — semantic tokens, tested patterns, focus management done right — quality becomes the default and review cycles shrink. I've cut them by 30%.
          </p>
          <p>
            I've also led cross-functional Frontend Guilds: aligning 6 distributed teams on shared standards through RFCs and pair programming, without relying on org chart authority.
          </p>
        </div>

        <dl class="about-meta">
          {[
            ['Focus',    'Frontend Architecture, Design Systems, A11y'],
            ['Stack',    'React · TypeScript · Node.js · CSS'],
            ['Based in', 'Buenos Aires, Argentina, Milky Way, Solar System'],
          ].map(([label, value]) => (
            <div class="meta-item">
              <dt class="meta-label">{label}</dt>
              <dd class="meta-value">{value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <!-- ── Work ── -->
      <section id="work" class="section" aria-labelledby="work-heading">
        <div class="section-header-mobile">
          <h2 id="work-heading">Work</h2>
        </div>

        <ul class="project-list" aria-label="Selected projects">
          {projects.map((p) => <ProjectCard {...p} />)}
        </ul>
      </section>

      <!-- ── Contact ── -->
      <section id="contact" class="section" aria-labelledby="contact-heading">
        <div class="section-header-mobile">
          <h2 id="contact-heading">Contact</h2>
        </div>

        <p class="contact-intro">
          If you're building something where frontend architecture matters, I'd like to hear about it.
        </p>

        <nav aria-label="Contact links">
          <ul class="contact-links" role="list">
            {[
              { href: 'mailto:merloleandro@gmail.com',        label: 'merloleandro@gmail.com',      external: false },
              { href: 'https://linkedin.com/in/merloleandro', label: 'linkedin.com/in/merloleandro', external: true  },
              { href: 'https://github.com/leomerlo',          label: 'github.com/leomerlo',          external: true  },
            ].map(({ href, label, external }) => (
              <li>
                <a
                  href={href}
                  class="contact-link"
                  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  <span class="contact-arrow" aria-hidden="true">→</span>
                  <span>{label}</span>
                  {external && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-ext-icon" aria-label="opens in new tab" role="img">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </section>

    </main>
  </div>
</BaseLayout>
