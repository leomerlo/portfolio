---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactSection from '../../components/ContactSection.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { ArrowLeft, ArrowUpRight, ArrowDown } from 'lucide-astro';
import { projects } from '../../data/projects';
import { ui } from '../../i18n/ui';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { i18nKey, title, description, metric, tags, url } = project;

const t = (key: string) => (ui.en as Record<string, string>)[key];

const accents: Record<string, { main: string; soft: string; alt: string; text: string }> = {
  project1: { main: 'bg-brand-purple', soft: 'bg-brand-purple/10', alt: 'bg-brand-yellow', text: 'text-brand-purple' },
  project2: { main: 'bg-brand-yellow', soft: 'bg-brand-yellow/10', alt: 'bg-brand-purple', text: 'text-brand-purple' },
  project3: { main: 'bg-brand-pink', soft: 'bg-brand-pink/10', alt: 'bg-brand-lavender', text: 'text-brand-pink' },
};
const accent = accents[i18nKey] ?? accents.project1;
---

<BaseLayout title={`${title} — Leo Merlo`} description={description}>
  <div class="h-[60px] bg-gradient-to-b from-brand-pink/5 to-white w-full absolute top-0 left-0"></div>

  <div class="max-w-screen-xl mx-auto px-6 relative pb-24">
    <header class="relative flex justify-between items-center py-6 border-b border-gray-200 text-sm" aria-label="Site header">
      <a href="/" class="flex items-center gap-2">
        <ArrowLeft class="w-4 h-4" />
        <span data-i18n="detail.back">Back to home</span>
      </a>
      <div class="absolute left-1/2 -translate-x-1/2 text-2xl pointer-events-none select-none">Leo Merlo</div>
    </header>

    <main id="main-content" class="flex flex-col pt-16" tabindex="-1">

      <!-- ── Hero ─────────────────────────────────────────── -->
      <section class="flex flex-col gap-8">
        <span class="border border-black rounded-full text-sm inline self-start py-1 px-4" data-i18n={`${i18nKey}.metric`}>{metric}</span>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold leading-[0.95] tracking-tight max-w-5xl" data-i18n={`${i18nKey}.title`}>{title}</h1>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
          <p class="text-lg md:text-2xl max-w-2xl leading-snug" data-i18n={`${i18nKey}.description`}>{description}</p>
          <div class="flex gap-2 flex-wrap md:justify-end md:max-w-xs">
            {tags.map((tag, index) => (
              <span class={`rounded-full px-4 py-1 text-xs whitespace-nowrap ${index % 2 === 0 ? 'border border-black' : 'bg-black text-white'}`}>{tag}</span>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Hero image ───────────────────────────────────── -->
      <div class={`mt-12 relative ${accent.main} aspect-[21/9] w-full overflow-hidden`} role="img" aria-label={title}>
        <span class="placeholder-label">Hero image</span>
        <div class={`absolute -right-16 -bottom-16 w-64 h-64 rounded-full ${accent.alt}`}></div>
        <div class="absolute left-8 bottom-8 w-16 h-16 rounded-full bg-white/30"></div>
      </div>

      <div class="flex items-center gap-2 mt-6 text-xs uppercase tracking-widest text-gray-500">
        <ArrowDown class="w-3 h-3" />
        <span>Case study</span>
      </div>

      <!-- ── 01 Situation ─────────────────────────────────── -->
      <section class="chapter" aria-labelledby="star-situation">
        <div class="chapter-head">
          <span class={`chapter-num ${accent.text}`}>01</span>
          <h2 id="star-situation" class="chapter-title" data-i18n="detail.situation">Situation</h2>
        </div>
        <p class="chapter-body" data-i18n={`${i18nKey}.star.situation`}>{t(`${i18nKey}.star.situation`)}</p>
      </section>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-12">
        <div class={`${accent.soft} aspect-square relative`}><span class="placeholder-label">Context</span></div>
        <div class={`${accent.main} md:col-span-2 relative`}><span class="placeholder-label">Before state</span></div>
      </div>

      <!-- ── 02 Task ──────────────────────────────────────── -->
      <section class="chapter" aria-labelledby="star-task">
        <div class="chapter-head">
          <span class={`chapter-num ${accent.text}`}>02</span>
          <h2 id="star-task" class="chapter-title" data-i18n="detail.task">Task</h2>
        </div>
        <p class="chapter-body" data-i18n={`${i18nKey}.star.task`}>{t(`${i18nKey}.star.task`)}</p>
      </section>

      <!-- ── 03 Action ────────────────────────────────────── -->
      <section class="chapter" aria-labelledby="star-action">
        <div class="chapter-head">
          <span class={`chapter-num ${accent.text}`}>03</span>
          <h2 id="star-action" class="chapter-title" data-i18n="detail.action">Action</h2>
        </div>
        <p class="chapter-body" data-i18n={`${i18nKey}.star.action`}>{t(`${i18nKey}.star.action`)}</p>
      </section>

      <div class="grid grid-cols-2 gap-3 mt-12">
        <div class={`${accent.alt} aspect-[4/3] relative`}><span class="placeholder-label">Process</span></div>
        <div class="bg-brand-lavender aspect-[4/3] relative"><span class="placeholder-label">Detail</span></div>
        <div class={`${accent.main} col-span-2 aspect-[21/9] relative`}>
          <span class="placeholder-label">Full-width outcome</span>
          <div class="absolute right-8 top-8 w-12 h-12 rounded-full bg-white/30"></div>
        </div>
      </div>

      <!-- ── 04 Result ────────────────────────────────────── -->
      <section class="chapter" aria-labelledby="star-result">
        <div class="chapter-head">
          <span class={`chapter-num ${accent.text}`}>04</span>
          <h2 id="star-result" class="chapter-title" data-i18n="detail.result">Result</h2>
        </div>
        <p class="chapter-body" data-i18n={`${i18nKey}.star.result`}>{t(`${i18nKey}.star.result`)}</p>
      </section>

      <div class={`${accent.main} mt-12 p-10 md:p-16 flex flex-col md:flex-row md:items-center gap-6 md:gap-16`}>
        <span class="text-5xl md:text-8xl font-bold text-white leading-none" data-i18n={`${i18nKey}.metric`}>{metric}</span>
        <span class="text-white/90 text-lg md:text-xl max-w-md" data-i18n={`${i18nKey}.description`}>{description}</span>
      </div>

      <!-- ── 05 Reflection ────────────────────────────────── -->
      <section class="chapter" aria-labelledby="star-reflection">
        <div class="chapter-head">
          <span class={`chapter-num ${accent.text}`}>05</span>
          <h2 id="star-reflection" class="chapter-title" data-i18n="detail.reflection">Reflection</h2>
        </div>
        <blockquote class={`border-l-4 pl-6 md:pl-10 mt-2 ${accent.text} border-current`}>
          <p class="text-xl md:text-3xl font-bold leading-snug text-black" data-i18n={`${i18nKey}.star.reflection`}>{t(`${i18nKey}.star.reflection`)}</p>
        </blockquote>
      </section>

      <!-- ── Footer CTA ───────────────────────────────────── -->
      <div class="mt-20 pt-10 border-t border-gray-200 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <a href="/" class="flex items-center gap-2 text-sm">
          <ArrowLeft class="w-4 h-4" />
          <span data-i18n="detail.back">Back to home</span>
        </a>
        {url && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg py-3 px-4 bg-black text-white flex items-center gap-4 text-sm"
          >
            <span data-i18n="detail.github">View on GitHub</span>
            <ArrowUpRight class="w-4 h-4" />
          </a>
        )}
      </div>

      <ContactSection />
    </main>
  </div>
  <SiteFooter />
</BaseLayout>

<style>
  .chapter {
    margin-top: 6rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .chapter {
      grid-template-columns: 1fr 2fr;
      gap: 3rem;
    }
  }

  .chapter-head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .chapter-num {
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
  }

  .chapter-title {
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .chapter-body {
    font-size: 1.125rem;
    line-height: 1.75;
    max-width: 42rem;
  }

  @media (min-width: 768px) {
    .chapter-body {
      font-size: 1.25rem;
    }
  }

  .placeholder-label {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(0, 0, 0, 0.35);
    background: rgba(255, 255, 255, 0.6);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }
</style>
