---
import { ArrowLeft, ArrowRight } from 'lucide-astro';
import ProjectBlock from './ProjectBlock.astro';
import { projects } from '../data/projects';
---

<div
  class="project-carousel"
  role="region"
  aria-roledescription="carousel"
  aria-label="Selected projects"
  data-i18n-aria="carousel.label"
>
  <div class="carousel-viewport">
    <div class="carousel-track flex items-start transition-transform duration-500 ease-out motion-reduce:transition-none" aria-live="off">
      {projects.map((p, i) => (
        <div
          class:list={['carousel-slide w-full shrink-0 overflow-hidden', { 'is-active': i === 0 }]}
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} / ${projects.length}`}
          aria-hidden={i === 0 ? 'false' : 'true'}
          inert={i !== 0}
        >
          <ProjectBlock {...p} />
        </div>
      ))}
    </div>
  </div>

  <div class="flex items-center justify-between mt-2">
    <div class="flex gap-2">
      {projects.map((p, i) => (
        <button
          type="button"
          class:list={['carousel-dot w-2.5 h-2.5 rounded-full border border-black transition-colors', { 'bg-black': i === 0 }]}
          data-index={i}
          aria-label={p.title}
          data-i18n-aria={`${p.i18nKey}.title`}
          aria-current={i === 0 ? 'true' : 'false'}
        />
      ))}
    </div>
    <div class="flex gap-2">
      <button
        type="button"
        class="carousel-prev w-10 h-10 rounded-full border border-black flex items-center justify-center hover:bg-black hover:text-white transition-colors"
        aria-label="Previous project"
        data-i18n-aria="carousel.prev"
      >
        <ArrowLeft class="w-4 h-4" />
      </button>
      <button
        type="button"
        class="carousel-next w-10 h-10 rounded-full border border-black flex items-center justify-center hover:bg-black hover:text-white transition-colors"
        aria-label="Next project"
        data-i18n-aria="carousel.next"
      >
        <ArrowRight class="w-4 h-4" />
      </button>
    </div>
  </div>
</div>

<style is:global>
  .carousel-viewport {
    overflow: hidden;
    cursor: grab;
  }

  .carousel-viewport.is-dragging {
    cursor: grabbing;
  }

  .carousel-viewport.is-dragging .carousel-track {
    transition: none;
  }

  .project-carousel.is-dragging,
  .project-carousel.is-dragging * {
    user-select: none;
  }

  .carousel-track {
    touch-action: pan-y;
  }

  @media (max-width: 767px) {
    .carousel-viewport {
      transition: height 300ms ease;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .carousel-slide.is-active .color-block {
      animation: carousel-block-in 0.5s ease-out backwards;
    }
  }

  @keyframes carousel-block-in {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  const AUTOPLAY_MS = 6000;
  const MOBILE_QUERY = '(max-width: 767px)';
  const carousel = document.querySelector<HTMLElement>('.project-carousel');

  if (carousel) {
    const viewport = carousel.querySelector<HTMLElement>('.carousel-viewport')!;
    const track = carousel.querySelector<HTMLElement>('.carousel-track')!;
    const slides = [...carousel.querySelectorAll<HTMLElement>('.carousel-slide')];
    const dots = [...carousel.querySelectorAll<HTMLElement>('.carousel-dot')];
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Stagger the color-block entrance within each slide
    slides.forEach((slide) => {
      slide.querySelectorAll<HTMLElement>('.color-block').forEach((block, i) => {
        block.style.animationDelay = `${i * 90}ms`;
      });
    });

    let index = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let slideWidth = viewport.clientWidth;
    let dragOffset = 0;
    let dragging = false;
    let dragStartX = 0;
    let dragMoved = false;

    function syncHeight() {
      if (window.matchMedia(MOBILE_QUERY).matches) {
        viewport.style.height = `${slides[index].offsetHeight}px`;
      } else {
        viewport.style.height = '';
      }
    }

    function applyTransform() {
      track.style.transform = `translateX(${-(index * slideWidth) + dragOffset}px)`;
    }

    function goTo(next: number) {
      index = (next + slides.length) % slides.length;
      dragOffset = 0;
      applyTransform();
      slides.forEach((slide, i) => {
        const active = i === index;
        slide.classList.toggle('is-active', active);
        slide.setAttribute('aria-hidden', String(!active));
        slide.toggleAttribute('inert', !active);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-black', i === index);
        dot.setAttribute('aria-current', String(i === index));
      });
      syncHeight();
    }

    function stop() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
      track.setAttribute('aria-live', 'polite');
    }

    function start() {
      if (reduceMotion || timer) return;
      track.setAttribute('aria-live', 'off');
      timer = setInterval(() => goTo(index + 1), AUTOPLAY_MS);
    }

    function restart() {
      stop();
      start();
    }

    carousel.querySelector('.carousel-prev')?.addEventListener('click', () => {
      goTo(index - 1);
      restart();
    });
    carousel.querySelector('.carousel-next')?.addEventListener('click', () => {
      goTo(index + 1);
      restart();
    });
    dots.forEach((dot, i) =>
      dot.addEventListener('click', () => {
        goTo(i);
        restart();
      })
    );

    carousel.addEventListener('mouseenter', stop);
    carousel.addEventListener('mouseleave', start);
    carousel.addEventListener('focusin', stop);
    carousel.addEventListener('focusout', (e) => {
      if (!carousel.contains(e.relatedTarget as Node)) start();
    });

    // ── Drag to scroll (mouse + touch + pen via Pointer Events) ──
    viewport.addEventListener('pointerdown', (e) => {
      dragging = true;
      dragMoved = false;
      dragStartX = e.clientX;
      dragOffset = 0;
      viewport.setPointerCapture(e.pointerId);
      carousel.classList.add('is-dragging');
      viewport.classList.add('is-dragging');
      stop();
    });

    viewport.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      dragOffset = e.clientX - dragStartX;
      if (Math.abs(dragOffset) > 4) dragMoved = true;
      applyTransform();
    });

    function endDrag(e: PointerEvent) {
      if (!dragging) return;
      dragging = false;
      carousel.classList.remove('is-dragging');
      viewport.classList.remove('is-dragging');
      try {
        viewport.releasePointerCapture(e.pointerId);
      } catch {}

      const threshold = Math.min(80, slideWidth * 0.15);
      if (dragOffset <= -threshold) {
        goTo(index + 1);
      } else if (dragOffset >= threshold) {
        goTo(index - 1);
      } else {
        dragOffset = 0;
        applyTransform();
      }
      restart();
    }

    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);

    // Prevent a dragged link/button from firing its click on release
    carousel.addEventListener('click', (e) => {
      if (dragMoved) {
        e.preventDefault();
        e.stopPropagation();
        dragMoved = false;
      }
    }, { capture: true });

    // ── Keep width/height in sync with layout changes ──
    const resizeObserver = new ResizeObserver(() => {
      slideWidth = viewport.clientWidth;
      applyTransform();
      syncHeight();
    });
    resizeObserver.observe(viewport);

    goTo(0);
    start();
  }
</script>
