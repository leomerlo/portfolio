---
import { ArrowLeft, ArrowRight } from 'lucide-astro';
import ProjectBlock from './ProjectBlock.astro';
import { projects } from '../data/projects';
---

<div
  class="project-carousel"
  role="region"
  aria-roledescription="carousel"
  aria-label="Selected projects"
  data-i18n-aria="carousel.label"
>
  <div class="carousel-viewport">
    <div class="carousel-track" aria-live="off">
      {projects.map((p, i) => (
        <div
          class:list={['carousel-slide', { 'is-active': i === 0 }]}
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} / ${projects.length}`}
          aria-hidden={i === 0 ? 'false' : 'true'}
          inert={i !== 0}
        >
          <ProjectBlock {...p} />
        </div>
      ))}
    </div>
  </div>

  <div class="carousel-controls flex items-center justify-between mt-2">
    <div class="flex gap-2">
      {projects.map((p, i) => (
        <button
          type="button"
          class:list={['carousel-dot w-2.5 h-2.5 rounded-full border border-black transition-colors', { 'bg-black': i === 0 }]}
          data-index={i}
          aria-label={p.title}
          data-i18n-aria={`${p.i18nKey}.title`}
          aria-current={i === 0 ? 'true' : 'false'}
        />
      ))}
    </div>
    <div class="flex gap-2">
      <button
        type="button"
        class="carousel-prev w-10 h-10 rounded-full border border-black flex items-center justify-center hover:bg-black hover:text-white transition-colors"
        aria-label="Previous project"
        data-i18n-aria="carousel.prev"
      >
        <ArrowLeft class="w-4 h-4" />
      </button>
      <button
        type="button"
        class="carousel-next w-10 h-10 rounded-full border border-black flex items-center justify-center hover:bg-black hover:text-white transition-colors"
        aria-label="Next project"
        data-i18n-aria="carousel.next"
      >
        <ArrowRight class="w-4 h-4" />
      </button>
    </div>
  </div>
</div>

<style is:global>
  .carousel-viewport {
    overflow: hidden;
    cursor: grab;
  }

  .carousel-viewport.is-dragging {
    cursor: grabbing;
  }

  .project-carousel.is-dragging,
  .project-carousel.is-dragging * {
    user-select: none;
  }

  .carousel-track {
    position: relative;
    touch-action: pan-y;
    width: 100%;
  }

  .carousel-slide {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    pointer-events: none;
  }

  .carousel-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  const AUTOPLAY_MS = 6000;
  const MOBILE_QUERY = '(max-width: 767px)';
  const OUT_MS = 300;
  const IN_MS = 450;
  const STAGGER_MS = 80;

  const carousel = document.querySelector<HTMLElement>('.project-carousel');

  if (carousel) {
    const viewport = carousel.querySelector<HTMLElement>('.carousel-viewport')!;
    const track = carousel.querySelector<HTMLElement>('.carousel-track')!;
    const slides = [...carousel.querySelectorAll<HTMLElement>('.carousel-slide')];
    const dots = [...carousel.querySelectorAll<HTMLElement>('.carousel-dot')];
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let index = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let transitioning = false;
    let dragging = false;
    let dragStartX = 0;
    let dragOffset = 0;
    let dragMoved = false;

    function syncHeight() {
      const h = slides[index].offsetHeight;
      track.style.height = `${h}px`;
      if (window.matchMedia(MOBILE_QUERY).matches) {
        viewport.style.height = `${h}px`;
      } else {
        viewport.style.height = '';
      }
    }

    function clearAnimations(slide: HTMLElement) {
      const textEl = slide.querySelector<HTMLElement>('.project-text');
      const blocks = [...slide.querySelectorAll<HTMLElement>('.color-block')];
      [textEl, ...blocks].filter(Boolean).forEach((el) => {
        el!.getAnimations().forEach((a) => a.cancel());
        (el as HTMLElement).style.opacity = '';
        (el as HTMLElement).style.transform = '';
      });
    }

    function animateOut(slide: HTMLElement, dir: 'next' | 'prev') {
      const textEl = slide.querySelector<HTMLElement>('.project-text');
      const blocks = [...slide.querySelectorAll<HTMLElement>('.color-block')];
      const xOut = dir === 'next' ? '-60px' : '60px';

      if (textEl) {
        textEl.animate(
          [{ opacity: 1 }, { opacity: 0 }],
          { duration: OUT_MS, easing: 'ease', fill: 'forwards' }
        );
      }

      blocks.forEach((block) => {
        block.animate(
          [
            { opacity: 1, transform: 'translateX(0)' },
            { opacity: 0, transform: `translateX(${xOut})` },
          ],
          { duration: OUT_MS, easing: 'ease', fill: 'forwards' }
        );
      });
    }

    function animateIn(slide: HTMLElement, dir: 'next' | 'prev') {
      const textEl = slide.querySelector<HTMLElement>('.project-text');
      const blocks = [...slide.querySelectorAll<HTMLElement>('.color-block')];
      const xIn = dir === 'next' ? '60px' : '-60px';

      if (textEl) {
        textEl.animate(
          [{ opacity: 0 }, { opacity: 1 }],
          { duration: IN_MS, easing: 'ease', fill: 'backwards' }
        );
      }

      blocks.forEach((block, i) => {
        block.animate(
          [
            { opacity: 0, transform: `translateX(${xIn})` },
            { opacity: 1, transform: 'translateX(0)' },
          ],
          { duration: IN_MS, delay: i * STAGGER_MS, easing: 'ease', fill: 'backwards' }
        );
      });
    }

    function goTo(next: number, dir: 'next' | 'prev' = 'next') {
      if (transitioning || next === index) return;
      transitioning = true;

      const prevIndex = index;
      index = (next + slides.length) % slides.length;

      const prevSlide = slides[prevIndex];
      const nextSlide = slides[index];

      // Update dots immediately
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-black', i === index);
        dot.setAttribute('aria-current', String(i === index));
      });

      if (reduceMotion) {
        prevSlide.classList.remove('is-active');
        prevSlide.setAttribute('aria-hidden', 'true');
        prevSlide.setAttribute('inert', '');
        nextSlide.classList.add('is-active');
        nextSlide.setAttribute('aria-hidden', 'false');
        nextSlide.removeAttribute('inert');
        transitioning = false;
        syncHeight();
        return;
      }

      // Phase 1: animate out
      clearAnimations(prevSlide);
      animateOut(prevSlide, dir);

      // Phase 2: switch + animate in
      setTimeout(() => {
        prevSlide.classList.remove('is-active');
        prevSlide.setAttribute('aria-hidden', 'true');
        prevSlide.setAttribute('inert', '');

        nextSlide.classList.add('is-active');
        nextSlide.setAttribute('aria-hidden', 'false');
        nextSlide.removeAttribute('inert');

        syncHeight();
        clearAnimations(nextSlide);
        animateIn(nextSlide, dir);

        setTimeout(() => {
          transitioning = false;
        }, IN_MS + (nextSlide.querySelectorAll('.color-block').length - 1) * STAGGER_MS + 50);
      }, OUT_MS);
    }

    function stop() {
      if (timer) { clearInterval(timer); timer = null; }
      track.setAttribute('aria-live', 'polite');
    }

    function start() {
      if (reduceMotion || timer) return;
      track.setAttribute('aria-live', 'off');
      timer = setInterval(() => goTo(index + 1, 'next'), AUTOPLAY_MS);
    }

    function restart() { stop(); start(); }

    carousel.querySelector('.carousel-prev')?.addEventListener('click', () => {
      goTo(index - 1, 'prev'); restart();
    });
    carousel.querySelector('.carousel-next')?.addEventListener('click', () => {
      goTo(index + 1, 'next'); restart();
    });
    dots.forEach((dot, i) =>
      dot.addEventListener('click', () => {
        goTo(i, i > index ? 'next' : 'prev'); restart();
      })
    );

    carousel.addEventListener('mouseenter', stop);
    carousel.addEventListener('mouseleave', start);
    carousel.addEventListener('focusin', stop);
    carousel.addEventListener('focusout', (e) => {
      if (!carousel.contains(e.relatedTarget as Node)) start();
    });

    // ── Drag ──
    viewport.addEventListener('pointerdown', (e) => {
      dragging = true;
      dragMoved = false;
      dragStartX = e.clientX;
      dragOffset = 0;
      viewport.setPointerCapture(e.pointerId);
      carousel.classList.add('is-dragging');
      viewport.classList.add('is-dragging');
      stop();
    });

    viewport.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      dragOffset = e.clientX - dragStartX;
      if (Math.abs(dragOffset) > 4) dragMoved = true;
      slides[index].style.transform = `translateX(${dragOffset}px)`;
    });

    function endDrag(e: PointerEvent) {
      if (!dragging) return;
      dragging = false;
      carousel.classList.remove('is-dragging');
      viewport.classList.remove('is-dragging');
      try { viewport.releasePointerCapture(e.pointerId); } catch {}

      slides[index].style.transform = '';
      const threshold = Math.min(80, viewport.clientWidth * 0.15);
      if (dragOffset <= -threshold) { goTo(index + 1, 'next'); }
      else if (dragOffset >= threshold) { goTo(index - 1, 'prev'); }
      dragOffset = 0;
      restart();
    }

    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);

    carousel.addEventListener('click', (e) => {
      if (dragMoved) { e.preventDefault(); e.stopPropagation(); dragMoved = false; }
    }, { capture: true });

    const resizeObserver = new ResizeObserver(() => syncHeight());
    resizeObserver.observe(viewport);

    // Portal controls to the section header slot if available
    const slot = document.getElementById('carousel-controls-slot');
    const controls = carousel.querySelector<HTMLElement>('.carousel-controls');
    if (slot && controls) {
      controls.classList.remove('mt-2');
      slot.appendChild(controls);
    }

    syncHeight();
    start();
  }
</script>
