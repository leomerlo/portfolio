---
interface Props {
  i18nKey: string;
  title: string;
  description: string;
  summary: string;
  details: string;
  metric: string;
  tags: string[];
  url?: string;
}

const { i18nKey, title, description, summary, details, metric, tags, url } = Astro.props;
---

<li>
  <details class="card card-expand" aria-label={title}>
    <summary>
      <div class="card-header">
        <span class="card-title">
          <span data-i18n={`${i18nKey}.title`}>{title}</span>
          <svg class="expand-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </span>
        <span class="card-metric" data-i18n={`${i18nKey}.metric`}>{metric}</span>
      </div>
      <p class="card-description" data-i18n={`${i18nKey}.description`}>{description}</p>
      <ul class="card-tags" role="list" aria-label="Technologies">
        {tags.map((t) => <li><span class="tag">{t}</span></li>)}
      </ul>
    </summary>

    <div class="card-expand-body">
      <p data-i18n={`${i18nKey}.summary`}>{summary}</p>
      <p data-i18n={`${i18nKey}.details`}>{details}</p>
      {url && (
        <a href={url} target="_blank" rel="noopener noreferrer" class="card-link">
          View on GitHub →
        </a>
      )}
    </div>
  </details>
</li>
