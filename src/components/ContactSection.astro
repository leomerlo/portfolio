---
import { ArrowUpRight, Copy, Check } from 'lucide-astro';

const EMAIL = 'merloleandro@gmail.com';
const MAILTO = `mailto:${EMAIL}?subject=${encodeURIComponent("Let's talk — opportunity for Leo")}`;
---

<section id="contact" class="section pb-8 mt-16" aria-labelledby="contact-heading">
  <div class="grid grid-cols-1 md:grid-cols-2 items-center gap-12">
    <div class="flex flex-col gap-8">
      <h2 id="contact-heading" class="text-4xl md:text-5xl font-bold" data-i18n="contact.title">Let's build something solid.</h2>
      <span class="text-sm max-w-sm" data-i18n="contact.intro">If frontend architecture is a real constraint in what you're building — not an afterthought — I want to talk.</span>
      <div class="flex items-center gap-3 flex-wrap">
        <a href={MAILTO} class="rounded-lg py-3 px-4 bg-black text-white flex items-center gap-4 text-sm">
          <span data-i18n="contact.now">Contact Now</span>
          <ArrowUpRight class="w-4 h-4" />
        </a>
        <button
          type="button"
          class="copy-email rounded-lg py-3 px-4 border border-black flex items-center gap-3 text-sm"
          data-email={EMAIL}
          aria-label="Copy email"
          data-i18n-aria="contact.copy"
        >
          <span class="copy-email-text">{EMAIL}</span>
          <Copy class="w-4 h-4 copy-icon" />
          <Check class="w-4 h-4 copied-icon hidden" />
        </button>
      </div>
    </div>
    <nav aria-label="Contact links">
      <ul class="contact-links" role="list">
        {[
          { href: 'https://linkedin.com/in/merloleandro', label: 'linkedin.com/in/merloleandro' },
          { href: 'https://github.com/leomerlo',          label: 'github.com/leomerlo'          },
          { href: 'https://x.com/leomerlox',              label: 'x.com/leomerlox'              },
        ].map(({ href, label }) => (
          <li>
            <a href={href} class="contact-link flex items-center gap-2 whitespace-nowrap" target="_blank" rel="noopener noreferrer">
              <span class="contact-arrow flex-shrink-0" aria-hidden="true">→</span>
              <span class="flex items-center gap-1 min-w-0">
                {label}
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="opens in new tab" role="img" style="flex-shrink:0">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-email').forEach((btn) => {
    const copyIcon = btn.querySelector('.copy-icon');
    const copiedIcon = btn.querySelector('.copied-icon');
    const text = btn.querySelector('.copy-email-text');
    const email = btn.dataset.email!;
    let timer: ReturnType<typeof setTimeout> | null = null;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(email);
        copyIcon?.classList.add('hidden');
        copiedIcon?.classList.remove('hidden');
        if (text) text.textContent = document.documentElement.lang === 'es' ? '¡Copiado!' : 'Copied!';
        if (timer) clearTimeout(timer);
        timer = setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          copiedIcon?.classList.add('hidden');
          if (text) text.textContent = email;
        }, 2000);
      } catch {
        // Clipboard unavailable — fall back to selecting the text
        if (text) {
          const range = document.createRange();
          range.selectNodeContents(text);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
    });
  });
</script>
