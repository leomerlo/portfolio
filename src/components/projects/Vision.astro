---
interface Props {
  i18nKey: string;
  title: string;
  description: string;
  summary: string;
  details: string;
  metric: string;
  tags: string[];
  url?: string;
}

const { i18nKey, title, description, summary, details, metric, tags, url } = Astro.props;
---

<div class="grid grid-cols-2 py-6">
  <div class="flex flex-col justify-between w-2/3">
    <div class="flex flex-col gap-2">
      <h3 class="text-4xl">{title}</h3>
      <p class="text-sm my-6">{description}</p>
    </div>
    <div class="flex gap-2 flex-wrap">
      {tags.map((tag, index) => <span class={`rounded-full px-4 py-1 text-xs ${index % 2 === 0 ? 'border border-black' : 'bg-black text-white'}`}>{tag}</span>)}
    </div>
  </div>
  <div class="grid grid-cols-3 gap-3 w-full justify-self-end">
    <div class="bg-brand-purple/10 flex flex-col justify-center items-center">
      <span class="text-3xl">80%</span>
      <span class="text-xs">Dev team </br> adoption</span>
    </div>
    <div class="col-span-2 bg-brand-purple text-white flex flex-col justify-between p-3 h-32">
      <span class="text-lg font-bold">Speed & Quality</span>
      <span class="text-xs">~30% less QA &</br>Accessibility review cycles</span>
    </div>
    <div class="col-span-3 bg-brand-yellow bg-[url(/vision_main.png)] bg-right-top bg-cover bg-no-repeat p-3 h-56">
      <div class="flex flex-col h-full w-1/3 justify-self-start">
        <div>
          <span class="rounded-full py-1 px-4 text-xs bg-white text-black">+40 components</span>
        </div>
        <div class="flex-1 flex items-center">
          <span class="text-xs text-white">Treat the internal library as a product. By-weekly release, Semantic versioning</span>
        </div>
        <span class="text-lg font-bold text-white">Work closely on a cross-team effort</span>
      </div>
    </div>
  </div>
</div>