---
import { ArrowUpRight, BrainCog } from 'lucide-astro';
interface Props {
  i18nKey: string;
  slug: string;
  title: string;
  description: string;
  summary: string;
  details: string;
  metric: string;
  tags: string[];
  url?: string;
}

const { i18nKey, slug, title, description, summary, details, metric, tags, url } = Astro.props;
const detailUrl = `/projects/${slug}`;
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-0 py-6">
  <div class="project-text flex flex-col justify-between gap-6 md:gap-0">
    <div class="flex flex-col gap-2">
      <h3 class="text-3xl md:text-4xl"><a href={detailUrl} class="hover:underline" data-i18n={`${i18nKey}.title`}>{title}</a></h3>
      <p class="text-sm my-6" data-i18n={`${i18nKey}.description`}>{description}</p>
    </div>
    <div class="flex flex-col gap-6">
      <div class="flex gap-2 flex-wrap">
        {tags.map((tag, index) => <span class={`rounded-full px-4 py-1 text-xs ${index % 2 === 0 ? 'border border-black' : 'bg-black text-white'}`}>{tag}</span>)}
      </div>
      <a href={detailUrl} class="border-b border-black uppercase text-xs self-start flex items-center gap-1">
        <span data-i18n="project.view-more">View More</span> <ArrowUpRight class="w-2 h-2" />
      </a>
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:col-span-2">
    <div class="relative h-40 md:h-full z-10 overflow-hidden">
      <div class="color-block bg-brand-purple w-full h-full md:w-[350px] absolute flex items-center justify-center">
        <span class="text-xs uppercase tracking-widest text-white/30 rotate-90 whitespace-nowrap">[Booking UI — placeholder]</span>
      </div>
    </div>
    <div class="flex flex-col gap-2 z-20 justify-between">
      <div class="color-block bg-brand-yellow flex flex-col p-6 h-[180px]">
        <div class="flex justify-between items-center">
          <span class="text-lg font-bold" data-i18n={`${i18nKey}.block.ai.title`}>AI Assistance speed</span>
          <ArrowUpRight class="w-4 h-4" />
        </div>
        <div class="flex justify-between items-end flex-1">
          <span class="text-xs">0x</span>
          <span class="text-6xl">5x</span>
          <span class="text-xs">10x</span>
        </div>
      </div>
      <div class="flex flex-col items-end gap-4">
        <div class="w-2/3">
          <span class="rounded-full px-4 py-1 text-xs border border-black" data-i18n={`${i18nKey}.block.claude`}>Claude Code</span>
        </div>
        <div class="w-2/3"><span class="text-xs" data-i18n={`${i18nKey}.block.spec`}>Spec driven development</span></div>
      </div>
    </div>
    <div class="flex flex-col items-center justify-between gap-4">
      <span class="text-3xl text-center my-6 mx-8" data-i18n={`${i18nKey}.block.fullstack`}>Fullstack workflow</span>
      <div class="color-block rounded-full bg-brand-lavender w-12 h-12 flex items-center justify-center"><BrainCog class="w-6 h-6" /></div>
      <a href={url} target="_blank" rel="noopener noreferrer" class="rounded-full px-4 py-1 text-xs bg-black text-white flex items-center gap-1">
        GitHub <ArrowUpRight class="w-3 h-3" />
      </a>
    </div>
  </div>
</div>
